# ═══════════════════════════════════════
# КАМ'ЯНА КОРОНА — Environment Variables
# Скопіюй в .env і заповни своїми даними
# ═══════════════════════════════════════

# PostgreSQL (з Supabase → Settings → Database → Connection string)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# JWT Secret (придумай будь-який довгий рядок)
JWT_SECRET=my-super-secret-key-change-this-123456

# Середовище
NODE_ENV=production

# Порт (Railway встановлює автоматично)
PORT=3000
